import React, { useState } from 'react';
import { AgentState, AgentAction, PlatformName } from '../types';
import { Pill, ShoppingBag, Clock, Bell, ShieldCheck, Activity, CheckCircle, CreditCard, ShoppingCart, Link, Lock, X, Loader2, Wifi, WifiOff } from 'lucide-react';

interface AgentDashboardProps {
  state: AgentState;
  dispatch: React.Dispatch<AgentAction>;
}

const BACKEND_URL = 'http://localhost:5001';

const AgentDashboard: React.FC<AgentDashboardProps> = ({ state, dispatch }) => {
  const [connectingPlatform, setConnectingPlatform] = useState<PlatformName | null>(null);
  const [username, setUsername] = useState('');
  const [password, setPassword] = useState('');
  const [isAuthenticating, setIsAuthenticating] = useState(false);
  const [authStatus, setAuthStatus] = useState<string>('');
  const [authError, setAuthError] = useState<string>('');

  const platforms: { id: PlatformName, color: string, icon: React.ReactNode }[] = [
    { id: 'Amazon', color: 'text-orange-600 bg-orange-50 border-orange-200', icon: <ShoppingCart className="w-4 h-4" /> },
    { id: 'Flipkart', color: 'text-blue-600 bg-blue-50 border-blue-200', icon: <ShoppingBag className="w-4 h-4" /> },
    { id: 'Apollo', color: 'text-teal-600 bg-teal-50 border-teal-200', icon: <Activity className="w-4 h-4" /> },
    { id: '1mg', color: 'text-red-600 bg-red-50 border-red-200', icon: <Pill className="w-4 h-4" /> },
  ];

  const initiateConnection = (platform: PlatformName) => {
    setConnectingPlatform(platform);
    setUsername('');
    setPassword('');
    setAuthStatus('');
    setAuthError('');
  };

  const handleLogin = async (e: React.FormEvent) => {
    e.preventDefault();
    if (!connectingPlatform) return;

    setIsAuthenticating(true);
    setAuthStatus('Launching secure browser...');
    setAuthError('');

    try {
      const response = await fetch(`${BACKEND_URL}/connect`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          platform: connectingPlatform,
          email: username,
          password: password
        })
      });

      const data = await response.json();

      // Show progress events
      if (data.events) {
        for (const event of data.events) {
          setAuthStatus(event.message || '');
          await new Promise(r => setTimeout(r, 300));
        }
      }

      if (data.success) {
        setAuthStatus('Connected successfully!');
        dispatch({ type: 'CONNECT_ACCOUNT', payload: connectingPlatform });
        setTimeout(() => {
          setConnectingPlatform(null);
          setUsername('');
          setPassword('');
        }, 1000);
      } else {
        setAuthError(data.message || 'Connection failed. Please check credentials.');
      }
    } catch (err) {
      console.error('Connect error:', err);
      setAuthStatus('');
      setAuthError('Could not reach the agent server. Make sure the Python backend is running on port 5001.');
    } finally {
      setIsAuthenticating(false);
    }
  };

  const handleDisconnect = async (platform: PlatformName) => {
    try {
      await fetch(`${BACKEND_URL}/disconnect`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ platform })
      });
    } catch {
      // Backend may not be running, that's ok
    }
    dispatch({ type: 'DISCONNECT_ACCOUNT', payload: platform });
  };

  return (
    <div className="relative h-full w-full bg-white border-l border-gray-200">
      {/* Main Dashboard Content */}
      <div className="h-full overflow-y-auto">
        <div className="p-4 border-b border-gray-100">
          <div className="flex items-center gap-2 mb-1">
            <ShieldCheck className="w-5 h-5 text-medical-600" />
            <h2 className="font-semibold text-gray-800">HealthGuard Agent</h2>
          </div>
          <p className="text-xs text-gray-500">Secure • Local-First • Active</p>
        </div>

        <div className="p-4 space-y-6">
          {/* Vitals */}
          <div>
            <h3 className="text-xs font-bold text-gray-400 uppercase tracking-wider mb-3 flex items-center gap-1">
              <Activity className="w-3 h-3" /> Daily Vitals
            </h3>
            <div className="grid grid-cols-2 gap-2">
              <div className="bg-gray-50 border border-gray-200 p-2 rounded-lg text-center">
                <span className="block text-lg font-bold text-gray-800">72</span>
                <span className="text-[10px] text-gray-500">BPM</span>
              </div>
              <div className="bg-gray-50 border border-gray-200 p-2 rounded-lg text-center">
                <span className="block text-lg font-bold text-gray-800">850</span>
                <span className="text-[10px] text-gray-500">Kcal</span>
              </div>
            </div>
          </div>

          {/* Connected Services */}
          <div>
            <h3 className="text-xs font-bold text-gray-400 uppercase tracking-wider mb-3 flex items-center gap-1">
              <Link className="w-3 h-3" /> Linked Services
            </h3>
            <div className="space-y-2">
              {platforms.map((p) => {
                const isConnected = state.connectedAccounts[p.id];
                return (
                  <div key={p.id} className={`flex items-center justify-between p-2.5 rounded-lg border transition-all ${isConnected
                    ? 'bg-white border-medical-200 shadow-sm'
                    : 'bg-gray-50 border-gray-200 opacity-80 hover:opacity-100'
                    }`}>
                    <div className="flex items-center gap-2">
                      <div className={`p-1.5 rounded-md border ${p.color}`}>
                        {p.icon}
                      </div>
                      <div>
                        <span className="text-sm font-medium text-gray-700">{p.id}</span>
                        {isConnected && (
                          <div className="flex items-center gap-1">
                            <Wifi className="w-2.5 h-2.5 text-medical-600" />
                            <span className="text-[9px] text-medical-600 font-medium">Live Session</span>
                          </div>
                        )}
                      </div>
                    </div>
                    <button
                      onClick={() => {
                        if (isConnected) {
                          handleDisconnect(p.id);
                        } else {
                          initiateConnection(p.id);
                        }
                      }}
                      className={`text-[10px] font-semibold px-2.5 py-1 rounded-full transition-all ${isConnected
                        ? 'bg-red-50 text-red-600 hover:bg-red-100'
                        : 'bg-medical-50 text-medical-600 hover:bg-medical-100'
                        }`}
                    >
                      {isConnected ? 'Disconnect' : 'Connect'}
                    </button>
                  </div>
                );
              })}
            </div>
            <p className="text-[10px] text-gray-500 mt-2">
              Connecting accounts allows HealthGuard to automatically place orders using local credentials.
            </p>
          </div>

          {/* Orders */}
          <div>
            <h3 className="text-xs font-bold text-gray-400 uppercase tracking-wider mb-3 flex items-center gap-1">
              <ShoppingBag className="w-3 h-3" /> Recent Orders
            </h3>
            {state.orders.length === 0 ? (
              <div className="text-sm text-gray-500 italic">No active orders</div>
            ) : (
              <ul className="space-y-3">
                {state.orders.map((order) => (
                  <li key={order.id} className="bg-white border border-gray-200 rounded-lg p-3 shadow-sm hover:shadow-md transition-all">
                    <div className="flex items-start justify-between mb-2">
                      <div className="flex items-center gap-2">
                        <div className={`p-1.5 rounded-full ${order.type === 'medicine' ? 'bg-red-50 text-red-500' : 'bg-green-50 text-green-500'}`}>
                          <Pill className="w-3 h-3" />
                        </div>
                        <span className="text-xs font-bold bg-gray-100 text-gray-600 px-1.5 py-0.5 rounded">
                          {order.platform || 'Online'}
                        </span>
                      </div>
                      {order.paymentStatus === 'paid' && (
                        <span className="flex items-center gap-1 text-[10px] text-green-600 font-semibold bg-green-50 px-1.5 py-0.5 rounded-full border border-green-100">
                          <CheckCircle className="w-3 h-3" /> Paid
                        </span>
                      )}
                    </div>

                    <p className="text-sm font-semibold text-gray-800 mb-1">{order.item}</p>

                    <div className="flex justify-between items-end">
                      <div className="text-xs text-gray-500">
                        <p className="capitalize text-medical-600">{order.status}</p>
                        <p className="text-[10px]">{new Date(order.timestamp).toLocaleTimeString()}</p>
                      </div>
                      {order.price && (
                        <div className="flex items-center gap-1 text-xs font-bold text-gray-700">
                          <CreditCard className="w-3 h-3 text-gray-400" />
                          {order.price}
                        </div>
                      )}
                    </div>
                  </li>
                ))}
              </ul>
            )}
          </div>

          {/* Alerts */}
          <div>
            <h3 className="text-xs font-bold text-gray-400 uppercase tracking-wider mb-3 flex items-center gap-1">
              <Bell className="w-3 h-3" /> Active Alerts
            </h3>
            {state.alerts.length === 0 ? (
              <div className="text-sm text-gray-500 italic">No alerts set</div>
            ) : (
              <ul className="space-y-2">
                {state.alerts.map((alert) => (
                  <li key={alert.id} className="flex items-center justify-between bg-yellow-50 p-2 rounded border border-yellow-100">
                    <div className="flex items-center gap-2">
                      <Clock className="w-4 h-4 text-yellow-600" />
                      <div>
                        <p className="text-sm font-medium text-gray-800">{alert.message}</p>
                        <p className="text-xs text-gray-500">{alert.time}</p>
                      </div>
                    </div>
                    <div className={`w-2 h-2 rounded-full ${alert.active ? 'bg-green-500' : 'bg-gray-400'}`} />
                  </li>
                ))}
              </ul>
            )}
          </div>
        </div>
      </div>

      {/* Login Modal Overlay */}
      {connectingPlatform && (
        <div className="absolute inset-0 z-50 flex items-center justify-center p-4 bg-black/50 backdrop-blur-sm transition-all duration-300">
          <div className="bg-white rounded-2xl shadow-2xl w-full max-w-xs p-6 border border-gray-100" style={{ animation: 'zoomIn 0.2s ease-out' }}>
            <div className="flex justify-between items-center mb-5">
              <h3 className="text-sm font-bold text-gray-800 flex items-center gap-2">
                <Lock className="w-4 h-4 text-medical-600" />
                Connect to {connectingPlatform}
              </h3>
              <button
                onClick={() => { setConnectingPlatform(null); setAuthError(''); }}
                className="text-gray-400 hover:text-gray-600 p-1 hover:bg-gray-100 rounded-full transition-colors"
              >
                <X className="w-4 h-4" />
              </button>
            </div>

            <form onSubmit={handleLogin} className="space-y-3">
              <div>
                <label className="block text-xs font-semibold text-gray-500 mb-1.5">Email or Mobile</label>
                <input
                  type="text"
                  value={username}
                  onChange={e => setUsername(e.target.value)}
                  className="w-full bg-gray-50 border border-gray-200 rounded-lg px-3 py-2 text-sm text-gray-900 focus:bg-white focus:ring-2 focus:ring-medical-500/50 focus:border-medical-500 outline-none transition-all placeholder-gray-400"
                  placeholder="user@example.com"
                  required
                  disabled={isAuthenticating}
                />
              </div>
              <div>
                <label className="block text-xs font-semibold text-gray-500 mb-1.5">Password</label>
                <input
                  type="password"
                  value={password}
                  onChange={e => setPassword(e.target.value)}
                  className="w-full bg-gray-50 border border-gray-200 rounded-lg px-3 py-2 text-sm text-gray-900 focus:bg-white focus:ring-2 focus:ring-medical-500/50 focus:border-medical-500 outline-none transition-all placeholder-gray-400"
                  placeholder="••••••••"
                  required
                  disabled={isAuthenticating}
                />
              </div>

              {/* Status */}
              {authStatus && !authError && (
                <div className="flex items-center gap-2 text-xs text-medical-700 bg-medical-50 p-2 rounded-lg border border-medical-100">
                  <Loader2 className="w-3 h-3 animate-spin" />
                  {authStatus}
                </div>
              )}

              {/* Error */}
              {authError && (
                <div className="text-xs text-red-600 bg-red-50 p-2 rounded-lg border border-red-100">
                  {authError}
                </div>
              )}

              <div className="pt-1">
                <button
                  type="submit"
                  disabled={isAuthenticating}
                  className="w-full bg-medical-600 text-white rounded-lg py-2.5 text-sm font-bold hover:bg-medical-700 active:scale-95 transition-all flex items-center justify-center gap-2 disabled:opacity-70 disabled:cursor-not-allowed shadow-lg shadow-medical-200"
                >
                  {isAuthenticating ? (
                    <>
                      <Loader2 className="w-4 h-4 animate-spin" />
                      Connecting...
                    </>
                  ) : (
                    "Secure Login"
                  )}
                </button>
                <p className="text-[10px] text-center text-gray-400 mt-2.5 flex items-center justify-center gap-1">
                  <ShieldCheck className="w-3 h-3" /> Credentials are not stored. Session-only.
                </p>
              </div>
            </form>
          </div>
        </div>
      )}
    </div>
  );
};

export default AgentDashboard;